# HTTP port for the mock server
PORT=3000

# Path to schema.json (source of truth for routes)
SCHEMA_PATH=./schema.json

# Artificial response delay in ms (0-30000), useful for UI loading states
RESPONSE_DELAY_MS=0

# Reload schema.json without restart (default: true in dev, false in production)
SCHEMA_HOT_RELOAD=true

# Allowed CORS origins, comma-separated
CORS_ORIGIN=http://localhost:5173,https://smart-mock-ui.vercel.app
